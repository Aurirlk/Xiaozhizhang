# 小智语音交互服务 - 环境变量配置模板

# ========================
# DeepSeek API 配置 (LLM - 主选)
# ========================
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-v4-flash

# ========================
# MiMo TTS API 配置 (主选)
# ========================
MIMO_TTS_API_KEY=your_mimo_tts_api_key_here
MIMO_TTS_API_URL=https://api.minimax.chat/v1/t2a_v2
MIMO_TTS_MODEL=mimo-v2.5-tts

# ========================
# MiniMax API 配置 (备份 LLM + TTS)
# ========================
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_minimax_group_id_here
MINIMAX_LLM_URL=https://api.minimax.chat/v1/text/chatcompletion_v2
MINIMAX_LLM_MODEL=MiniMax-Text-01
MINIMAX_TTS_URL=https://api.minimax.chat/v1/t2a_v2
MINIMAX_TTS_MODEL=speech-01

# ========================
# ASR 配置
# ========================
MINIMAX_ASR_URL=https://api.minimax.chat/v1/t2a_v2

# ========================
# TTS 配置
# ========================
TTS_VOICE=male-qn-qingse
TTS_SPEED=1.0

# ========================
# LLM 配置
# ========================
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# ========================
# 服务器配置
# ========================
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ========================
# 数据库配置
# ========================
# SQLite (开发环境)
DATABASE_URL=sqlite+aiosqlite:///./xiaozhi.db

# PostgreSQL (生产环境)
# DATABASE_URL=postgresql+asyncpg://xiaozhi:password@localhost:5432/xiaozhi
